# Example environment configuration for MovieTcktBooking
# Copy this to .env and fill in real values (do NOT commit .env)

# Django Secret Key
SECRET_KEY=your-django-secret-key

# Web Server Settings
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True

# Database URL
# DATABASE_URL=mysql://user:password@hostname:port/dbname

# Stripe Testing Keys
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
